# Source files - only ship compiled JavaScript
client/src/**
server/src/**
common/**/*.ts
**/*.map

# TypeScript configuration
**/tsconfig*.json
.mocharc.json

# Development and testing
test-programs/**
ExampleCode/**
demo-*.clw
Logs/**

# Documentation (not needed at runtime)
docs/**
*.md
!README.md
!CHANGELOG.md
!LICENSE

# Development guides and notes
PUBLISHING_GUIDE.md
TESTING.md
TODO.md
KNOWN_ISSUES.md
vsc-extension-quickstart.md
SESSION_RESUME*.md
STARTUP_AI_PROMPT.md
TIER1_MINIMAL_PROMPT.md
ClarionExtensionFeatures.md
WelcomePanel.png

# Release files and old versions
releases/**
*.vsix
clarion-extensions-*.vsix

# AI prompts and development context
prompt/**
ai/**
dev/**

# ANTLR grammar source (not needed at runtime - only compiled output matters)
antlr-grammar/**

# Large documentation/reference folders not needed at runtime
ClarionDocs/**

# Development test files
test-compile-folding.clw
test-declaration-debug.js
test-declaration-patterns.js

# Git and GitHub
.git/**
.gitignore
.gitattributes
.github/**

# VS Code workspace files
.vscode/**
.vscode-test/**
*.code-workspace
Clarion-Extension.code-workspace

# Node modules are not needed — extension bundles all dependencies via esbuild
node_modules/**
client/node_modules/**
server/node_modules/**

# Log files
*.log
server.log

# Announcement and release notes (development only)
discourse-announcement.md
release-announcement-*.md

# Required files (explicitly NOT ignored):
# - out/** (compiled/bundled extension code — client and server bundles)
# - syntaxes/** (language grammar)
# - snippets/** (code snippets)
# - images/** (extension icons)
# - package.json (extension manifest)
# - README.md (marketplace description) - root only
# - CHANGELOG.md (version history) - root only
# - LICENSE (required) - root only
